+    /**
+     * Move the uploaded temp file into a stable managed path before image editing.
+     *
+     * @param string $source_path Original uploaded temp file path.
+     * @param string $destination_path Managed staging path.
+     * @return true|WP_Error
+     */
+    private static function stage_uploaded_source($source_path, $destination_path) {
+        $source_path = (string) $source_path;
+        $destination_path = (string) $destination_path;
+
+        if ($source_path === '' || !is_file($source_path) || !is_readable($source_path)) {
+            return new WP_Error('photo_temp_unavailable', 'The uploaded photo temporary file could not be read before processing.', ['status' => 500]);
+        }
+
+        $staged = false;
+
+        if (function_exists('is_uploaded_file') && function_exists('move_uploaded_file') && is_uploaded_file($source_path)) {
+            $staged = @move_uploaded_file($source_path, $destination_path);
+        }
+
+        if (!$staged) {
+            $staged = @copy($source_path, $destination_path);
+        }
+
+        if (!$staged) {
+            return new WP_Error('photo_stage_failed', 'The uploaded photo could not be staged for processing.', ['status' => 500]);
+        }
+
+        if (!is_file($destination_path) || !is_readable($destination_path)) {
+            return new WP_Error('photo_stage_failed', 'The staged photo file could not be read for processing.', ['status' => 500]);
+        }
+
+        return true;
+    }
